# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# build output and tool caches
/dist/
/build/
/.next/
/out/
/.wrangler/
/.vite/
/.cache/
.eslintcache
*.tsbuildinfo
next-env.d.ts
vite.config.*.timestamp-*

# testing
/coverage/
/playwright-report/
/blob-report/
/test-results/
/.nyc_output/

# local environment and deployment state
.env*
!.env.example
.dev.vars
!.dev.vars.example
.vercel/

# editors and operating systems
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# credentials and debug logs
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.har

# local source asset packages
Peppa & Dolly assets-*.zip

# temporary and local work files
/tmp/
*.tmp
*.temp
/public/assets/audio/*.tmp.*
/.worktrees/
/.playwright-mcp/
